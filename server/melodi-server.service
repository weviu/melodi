[Unit]
Description=Melodi Download Server
After=network.target

[Service]
Type=simple
User=melodi
WorkingDirectory=/opt/melodi-server
EnvironmentFile=/opt/melodi-server/.env
ExecStart=/opt/melodi-server/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080
Restart=on-failure
RestartSec=5

# Sandboxing
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/melodi-server/logs

[Install]
WantedBy=multi-user.target
